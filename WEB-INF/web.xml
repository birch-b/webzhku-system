<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

  <filter>
    <filter-name>EncodingFilter</filter-name>
    <filter-class>com.taobao.filter.EncodingFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>EncodingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>com.taobao.filter.AuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/admin/*</url-pattern>
    <url-pattern>/shop/*</url-pattern>
    <url-pattern>/customer/*</url-pattern>
    <url-pattern>/cart/*</url-pattern>
    <url-pattern>/order/*</url-pattern>
    <url-pattern>/payment/*</url-pattern>
    <url-pattern>/review/*</url-pattern>
    <url-pattern>/aftersale/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>ShopAuthFilter</filter-name>
    <filter-class>com.taobao.filter.ShopAuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>ShopAuthFilter</filter-name>
    <url-pattern>/shop/*</url-pattern>
  </filter-mapping>

  <welcome-file-list>
    <welcome-file>index</welcome-file>
  </welcome-file-list>
</web-app>
